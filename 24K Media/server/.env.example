# Port the 24K Media API listens on (Render sets this automatically)
PORT=4000

# Comma-separated list of allowed CORS origins (frontend URLs).
# In production set this to your Vercel domain(s).
CORS_ORIGIN=http://localhost:5173

# ── Supabase (database) ───────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# SECRET — service_role key (Dashboard → Project Settings → API).
# Never commit this or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: forward new leads to an external CRM / webhook (e.g. Zapier, n8n)
LEAD_WEBHOOK_URL=
